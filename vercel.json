{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run build --w client",
  "outputDirectory": "client/dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/uploads/(.*)", "destination": "/api" },
    { "source": "/((?!api|uploads|favicon.svg|assets).*)", "destination": "/index.html" }
  ]
}
