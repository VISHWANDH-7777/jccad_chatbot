# Server configuration
PORT=5000

# Database configuration
MONGODB_URI=mongodb+srv://user:password@cluster.example.mongodb.net/jccad_platform

# Frontend origin allowed by CORS
CORS_ORIGIN=https://your-frontend-url.vercel.app

# LLM Providers API Keys (Gemini or Groq)
# Set GEMINI_API_KEY to your Google AI Studio key (starts with AIzaSy)
# Or set to your Groq API key (starts with gsk_) to enable Groq Llama 3 fallback integration
GEMINI_API_KEY=

# LLM Models Configuration
GEMINI_MODEL=gemini-3.5-flash
GROQ_MODEL=llama-3.1-8b-instant

# JWT secrets for authentication
JWT_SECRET=
REFRESH_SECRET=
