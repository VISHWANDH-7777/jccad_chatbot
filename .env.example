# Frontend
VITE_API_URL=https://your-backend-url.com
VITE_API_PROXY_TARGET=https://your-backend-url.com

# Backend
MONGODB_URI=mongodb+srv://user:password@cluster.example.mongodb.net/jccad_platform
GEMINI_API_KEY=your-gemini-or-groq-api-key
GEMINI_MODEL=gemini-2.5-flash
GROQ_MODEL=llama-3.1-8b-instant
PORT=5000
CORS_ORIGIN=https://your-frontend-url.vercel.app
# Server configuration
PORT=5000

# Database configuration
MONGODB_URI=mongodb://127.0.0.1:27017/jccad_platform

# LLM Providers API Keys (Gemini or Groq)
# Set GEMINI_API_KEY to your Google AI Studio key (starts with AIzaSy)
# Or set to your Groq API key (starts with gsk_) to enable Groq Llama 3 fallback integration
GEMINI_API_KEY=

# LLM Models Configuration
GEMINI_MODEL=gemini-3.5-flash
GROQ_MODEL=llama-3.1-8b-instant

# JWT secrets for authentication
JWT_SECRET=
REFRESH_SECRET=
